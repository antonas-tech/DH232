# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Direct PostgreSQL connection used by Prisma
# Use the Supabase "Connection string" with the postgres-js pooler for runtime,
# and the direct URL for migrations.
DATABASE_URL="postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Storage bucket names (must exist in your Supabase project)
SUPABASE_BUCKET_AVATARS="avatars"
SUPABASE_BUCKET_SAMPLES="samples"
SUPABASE_BUCKET_BEATS="beats"
SUPABASE_BUCKET_COVERS="covers"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
